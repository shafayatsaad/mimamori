// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model CarePlan {
  id                    String   @id @default(cuid())
  patientEmail          String   @unique
  
  // Hydration goal overrides
  hydrationHotTemp      Float?
  hydrationWarmTemp     Float?
  hydrationHotGoalMl    Int?
  hydrationWarmGoalMl   Int?
  hydrationColdGoalMl   Int?
  
  // Intake validation overrides
  intakeMinMl           Int?
  intakeMaxMl           Int?
  
  // Low-hydration warning overrides
  lowHydrationHour      Int?
  lowHydrationPercent   Int?
  
  // Hydration presets override
  hydrationPresetsMl    String?  // Comma-separated, e.g. "100,250,500"
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}


model PromptTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  template    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model PermissionType {
  id          String   @id @default(cuid())
  name        String   @unique  // e.g. "Diary", "Alerts", "Vault"
  description String?
  createdAt   DateTime @default(now())
}


model DocumentCategoryRule {
  id            String   @id @default(cuid())
  mimePattern   String   // e.g. "image/tiff", "application/pdf"
  extPattern    String?  // e.g. "tiff,tif"
  documentType  String   // e.g. "Imaging", "Doctor Note"
  priority      Int      @default(0)
  createdAt     DateTime @default(now())
}
