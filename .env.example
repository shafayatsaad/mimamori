# =============================================================================
# Mimamori Application — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the required values.
# DO NOT commit .env.local to version control.
#
# Variables marked [REQUIRED] have no defaults and will cause a startup error
# if missing. All others fall back to the default shown.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS / Infrastructure  (Req 1.1, 1.2, 1.3)
# -----------------------------------------------------------------------------
# AWS credentials are resolved via the SDK default provider chain:
#   - Production: IAM role / ECS task role / EC2 instance profile
#   - Local dev:  ~/.aws/credentials or AWS_* env vars set outside this file
# Do NOT put AWS access keys in this file.

# AWS region for all service clients
# Default: us-west-2
APP_REGION=us-west-2

# [REQUIRED] S3 bucket for document storage
APP_S3_BUCKET_NAME=

# [REQUIRED] SES verified sender email address
APP_SES_FROM_EMAIL=

# [REQUIRED] Bedrock prompt router ARN
APP_BEDROCK_ROUTER_ARN=

# [REQUIRED] DynamoDB table name for user records
MIMAMORI_USERS_TABLE=

# [REQUIRED] DynamoDB table name for health data
MIMAMORI_DATA_TABLE=

# -----------------------------------------------------------------------------
# Database (Prisma + PostgreSQL)
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string (with connection pooling)
# Example: postgres://user:pass@host:5432/dbname?pgbouncer=true
POSTGRES_PRISMA_URL=

# [REQUIRED] PostgreSQL direct connection string (for migrations)
# Example: postgres://user:pass@host:5432/dbname
POSTGRES_URL_NON_POOLING=

# -----------------------------------------------------------------------------
# Session / Authentication
# -----------------------------------------------------------------------------

# Secret used to sign JWT session tokens
# Default: mimamori-dev-secret-change-me  ← CHANGE THIS IN PRODUCTION
SESSION_JWT_SECRET=mimamori-dev-secret-change-me

# Session token lifetime in seconds (default: 86400 = 24 hours)
SESSION_EXPIRY_SECONDS=86400

# -----------------------------------------------------------------------------
# Hydration Engine
# -----------------------------------------------------------------------------

# Temperature threshold (°C) above which the "hot" hydration goal applies
# Default: 28
HYDRATION_HOT_TEMP=28

# Temperature threshold (°C) at or above which the "warm" goal applies
# Default: 20
HYDRATION_WARM_TEMP=20

# Daily hydration goal (mL) when temperature > HYDRATION_HOT_TEMP
# Default: 2500
HYDRATION_HOT_GOAL_ML=2500

# Daily hydration goal (mL) when temperature is between warm and hot
# Default: 2000
HYDRATION_WARM_GOAL_ML=2000

# Daily hydration goal (mL) when temperature < HYDRATION_WARM_TEMP
# Default: 1500
HYDRATION_COLD_GOAL_ML=1500

# Minimum allowed single intake amount (mL)
# Default: 50
INTAKE_MIN_ML=50

# Maximum allowed single intake amount (mL)
# Default: 2000
INTAKE_MAX_ML=2000

# Hour of day (0-23) at which low-hydration warnings activate
# Default: 15 (3 PM)
LOW_HYDRATION_HOUR=15

# Percentage of daily goal below which a low-hydration warning triggers
# Default: 50
LOW_HYDRATION_PERCENT=50

# Comma-separated quick-add hydration preset amounts (mL)
# Default: 200,350,500
HYDRATION_PRESETS_ML=200,350,500

# -----------------------------------------------------------------------------
# Weather API
# -----------------------------------------------------------------------------

# Base URL for weather data
# Default: https://api.open-meteo.com/v1/forecast
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Weather response cache time-to-live (milliseconds)
# Default: 1800000 (30 minutes)
WEATHER_CACHE_TTL_MS=1800000

# Weather API request timeout (milliseconds)
# Default: 5000
WEATHER_TIMEOUT_MS=5000

# Fallback temperature (°C) used when the weather API is unavailable
# Default: 20
WEATHER_DEFAULT_TEMP=20

# JSON array of city presets for weather lookups
# Default: [{"name":"Tokyo","lat":35.6762,"lon":139.6503},{"name":"New York","lat":40.7128,"lon":-74.006},{"name":"London","lat":51.5074,"lon":-0.1278},{"name":"Sydney","lat":-33.8688,"lon":151.2093}]
# CITY_PRESETS=

# -----------------------------------------------------------------------------
# AI Models
# -----------------------------------------------------------------------------

# Model ID for lightweight / micro tasks
# Default: amazon.nova-micro-v1:0
AI_MODEL_MICRO=amazon.nova-micro-v1:0

# Model ID for orchestration tasks
# Default: anthropic.claude-3-5-haiku-20241022-v1:0
AI_MODEL_ORCHESTRATOR=anthropic.claude-3-5-haiku-20241022-v1:0

# Model ID for analysis tasks
# Default: anthropic.claude-3-5-sonnet-20241022-v2:0
AI_MODEL_ANALYZER=anthropic.claude-3-5-sonnet-20241022-v2:0

# Model ID for processing tasks
# Default: amazon.nova-pro-v1:0
AI_MODEL_PROCESSOR=amazon.nova-pro-v1:0

# Model ID for specialist tasks
# Default: amazon.nova-premier-v1:0
AI_MODEL_SPECIALIST=amazon.nova-premier-v1:0

# -----------------------------------------------------------------------------
# Demo Mode
# -----------------------------------------------------------------------------

# Enable demo mode (true/false)
# Default: false
DEMO_MODE=false

# Join code accepted when demo mode is enabled (ignored when DEMO_MODE=false)
# Default: (empty)
DEMO_JOIN_CODE=

# -----------------------------------------------------------------------------
# Storage Prefixes
# -----------------------------------------------------------------------------

# Prefix for server-side localStorage keys
# Default: mimamori_
LOCALSTORAGE_PREFIX=mimamori_

# Prefix for client-side (Next.js public) storage keys
# Default: mimamori_
NEXT_PUBLIC_STORAGE_PREFIX=mimamori_

# -----------------------------------------------------------------------------
# Alert Emails
# -----------------------------------------------------------------------------

# Subject line for health alert emails
# Default: Mimamori Health Alert
ALERT_EMAIL_SUBJECT=Mimamori Health Alert

# Default alert email body template (used when no custom message is provided)
# Default: built-in multi-line template — override with a single-line string or
# leave unset to use the built-in default.
# ALERT_EMAIL_TEMPLATE=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Content Security Policy directives applied via next.config.mjs headers
# Default: default-src 'self'; script-src 'none'; sandbox;
CSP_DIRECTIVES=default-src 'self'; script-src 'none'; sandbox;
